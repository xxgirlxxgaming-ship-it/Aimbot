------------------------------------------------------

local FlickGuns = {}
local lastScanTime = 0
local scanInterval = 8

local function safeRawget(tbl, key)
    local ok, result = pcall(rawget, tbl, key)
    if ok then return result end
    return nil
end

local function isGunTable(obj)
    if type(obj) ~= "table" then return false end

    local ammoLike = safeRawget(obj, "Ammo")
        or safeRawget(obj, "CurrentAmmo")
        or safeRawget(obj, "Mag")
        or safeRawget(obj, "Clip")
        or safeRawget(obj, "Bullets")
        or safeRawget(obj, "AmmoInMag")

    local reloadLike = safeRawget(obj, "ReloadTime")
        or safeRawget(obj, "Reload")
        or safeRawget(obj, "Reloading")

    return ammoLike ~= nil and reloadLike ~= nil
end

function scanFlickGuns()
    if not getgc then
        print("[FrostHub DEBUG] getgc not supported, Flick No‑Reload disabled.")
        return
    end

    FlickGuns = {}

    for _, obj in ipairs(getgc(true)) do
        if isGunTable(obj) then
            table.insert(FlickGuns, obj)
        end
    end

    print("[FrostHub DEBUG] Flick gun tables found:", #FlickGuns)
end

local function patchGun(gun)
    pcall(function()
        if gun._FH_Patched then return end
        gun._FH_Patched = true
        print("[FrostHub DEBUG] Patched Flick gun table:", gun, gun.Name or gun.WeaponName or "[no name]")
    end)
end

local function applyFlickPatches()
    if not MiscConfig.NoReload_Flick then return end
    if #FlickGuns == 0 then return end

    for _, gun in ipairs(FlickGuns) do
        pcall(function()
            patchGun(gun)

            local magSize =
                safeRawget(gun, "MaxAmmo") or
                safeRawget(gun, "Clip") or
                safeRawget(gun, "Mag") or
                safeRawget(gun, "AmmoInMag") or
                safeRawget(gun, "Ammo") or
                30

            if gun.ReloadTime ~= nil then gun.ReloadTime = 0 end
            if type(gun.Reload) == "number" then gun.Reload = 0 end

            if gun.Ammo ~= nil and gun.Ammo < magSize then gun.Ammo = magSize end
            if gun.CurrentAmmo ~= nil and gun.CurrentAmmo < magSize then gun.CurrentAmmo = magSize end
            if gun.Mag ~= nil and gun.Mag < magSize then gun.Mag = magSize end
            if gun.Clip ~= nil and gun.Clip < magSize then gun.Clip = magSize end
            if gun.AmmoInMag ~= nil and gun.AmmoInMag < magSize then gun.AmmoInMag = magSize end
            if gun.Bullets ~= nil and gun.Bullets < magSize then gun.Bullets = magSize end

            if gun.MaxAmmo ~= nil and gun.MaxAmmo < 9999 then gun.MaxAmmo = 9999 end
            if gun.StoredAmmo ~= nil and gun.StoredAmmo < 9999 then gun.StoredAmmo = 9999 end
        end)
    end
end

