ChangeKeyCorner.CornerRadius = UDim.new(0, 8)
ChangeKeyCorner.Parent = ChangeKeyButton

local waitingForKey = false

ChangeKeyButton.MouseButton1Click:Connect(function()
    if waitingForKey then return end
    waitingForKey = true
    playClick()
    ChangeKeyButton.Text = "Press any key"
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- handle changing bind key first
    if waitingForKey and input.UserInputType == Enum.UserInputType.Keyboard then
        waitingForKey = false
        AimbotConfig.BindKey = input.KeyCode
        KeyHint.Text = "Hold " .. AimbotConfig.BindKey.Name .. " to aim"
        ChangeKeyButton.Text = "Change Bind"
        print("[FrostHub DEBUG] BindKey changed to:", AimbotConfig.BindKey.Name)
        return
    end

    -- normal aimbot key handling
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == AimbotConfig.BindKey and not waitingForKey then
        if AimbotConfig.HoldToAim then
            -- HOLD MODE: only active while key is down
            holdingKey = true
            print("[FrostHub DEBUG] Bind key DOWN (HOLD mode,", AimbotConfig.BindKey.Name, ")")
        else
            -- TOGGLE MODE: flip the active state each press
            toggleAimingActive = not toggleAimingActive
            print("[FrostHub DEBUG] Bind key PRESSED (TOGGLE mode,", AimbotConfig.BindKey.Name, ") =>", toggleAimingActive)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == AimbotConfig.BindKey then
        if AimbotConfig.HoldToAim then
            holdingKey = false
            print("[FrostHub DEBUG] Bind key UP (HOLD mode,", AimbotConfig.BindKey.Name, ")")
        end
    end
end)

