-- We declare FlickGuns & helpers before using them in the button callback
local FlickGuns = {}
local lastScanTime = 0
local scanInterval = 8 -- seconds between automatic rescans

local function safeRawget(tbl, key)
    local ok, result = pcall(rawget, tbl, key)
    if ok then return result end
    return nil
end

local function isGunTable(obj)
    if type(obj) ~= "table" then return false end

    -- Things we consider as signs of a gun table
    local ammoLike = safeRawget(obj, "Ammo")
        or safeRawget(obj, "CurrentAmmo")
        or safeRawget(obj, "Mag")
        or safeRawget(obj, "Clip")
        or safeRawget(obj, "Bullets")
        or safeRawget(obj, "AmmoInMag")

    local reloadLike = safeRawget(obj, "ReloadTime")
        or safeRawget(obj, "Reload")
        or safeRawget(obj, "Reloading")

    -- Sometimes Flick stores a Name or WeaponName
    local nameLike = safeRawget(obj, "Name") or safeRawget(obj, "WeaponName")

    return ammoLike ~= nil and reloadLike ~= nil and (nameLike ~= nil or true)
end

local function scanFlickGuns()
    if not getgc then
        print("[FrostHub DEBUG] getgc not supported by this executor, Flick No‑Reload will not work.")
        return
    end

    FlickGuns = {}

    for _, obj in ipairs(getgc(true)) do
        if isGunTable(obj) then
            table.insert(FlickGuns, obj)
        end
    end

    print("[FrostHub DEBUG] Flick gun tables found:", #FlickGuns)
    if #FlickGuns == 0 then
        print("[FrostHub DEBUG] Hint: Equip a gun in Flick, then press 'Rescan Flick Guns (Debug)' in MISC.")
    end
end

local function patchGun(gun)
    pcall(function()
        -- Cache originals only once
        if gun._FH_Patched then return end
        gun._FH_Patched = true

        gun._FH_Orig_A                   = safeRawget(gun, "Ammo")
        gun._FH_Orig_CurrentAmmo         = safeRawget(gun, "CurrentAmmo")
        gun._FH_Orig_Mag                 = safeRawget(gun, "Mag")
        gun._FH_Orig_Clip                = safeRawget(gun, "Clip")
        gun._FH_Orig_Bullets             = safeRawget(gun, "Bullets")
        gun._FH_Orig_AmmoInMag           = safeRawget(gun, "AmmoInMag")

        gun._FH_Orig_MaxAmmo             = safeRawget(gun, "MaxAmmo")
        gun._FH_Orig_StoredAmmo          = safeRawget(gun, "StoredAmmo")

        gun._FH_Orig_ReloadTime          = safeRawget(gun, "ReloadTime")
        gun._FH_Orig_Reload              = safeRawget(gun, "Reload")
        gun._FH_Orig_Reloading           = safeRawget(gun, "Reloading")
        gun._FH_Orig_CanReload           = safeRawget(gun, "CanReload")

        gun._FH_Orig_FireRate            = safeRawget(gun, "FireRate")
        gun._FH_Orig_ShotsPerTap         = safeRawget(gun, "ShotsPerTap")

        print("[FrostHub DEBUG] Patched Flick gun table:", gun, gun.Name or gun.WeaponName or "[no name]")
    end)
end

local function applyFlickPatches()
    if not MiscConfig.NoReload_Flick then return end
    if #FlickGuns == 0 then return end

    for _, gun in ipairs(FlickGuns) do
        pcall(function()
            patchGun(gun)

            -- Figure out a "mag size" to keep ammo topped up
            local magSize =
                safeRawget(gun, "MaxAmmo") or
                safeRawget(gun, "Clip") or
                safeRawget(gun, "Mag") or
                safeRawget(gun, "AmmoInMag") or
                safeRawget(gun, "Ammo") or
                30

            -- Kill reload time / flags
            if gun.ReloadTime ~= nil then gun.ReloadTime = 0 end
            if type(gun.Reload) == "number" then gun.Reload = 0 end
            if type(gun.Reload) == "function" then
                -- Replace function with dummy that instantly "finishes" reload
                gun.Reload = function(...)
                    if gun.Reloading ~= nil then gun.Reloading = false end
                    if gun.CanReload ~= nil then gun.CanReload = true end
                    -- keep ammo topped during any forced reload
                    if gun.Ammo ~= nil and gun.Ammo < magSize then gun.Ammo = magSize end
                    if gun.CurrentAmmo ~= nil and gun.CurrentAmmo < magSize then gun.CurrentAmmo = magSize end
                    if gun.Mag ~= nil and gun.Mag < magSize then gun.Mag = magSize end
                    if gun.Clip ~= nil and gun.Clip < magSize then gun.Clip = magSize end
                    if gun.AmmoInMag ~= nil and gun.AmmoInMag < magSize then gun.AmmoInMag = magSize end
                end
            end

            if gun.Reloading ~= nil then gun.Reloading = false end
            if gun.CanReload ~= nil then gun.CanReload = true end

            -- Force ammo
            if gun.Ammo ~= nil and gun.Ammo < magSize then gun.Ammo = magSize end
            if gun.CurrentAmmo ~= nil and gun.CurrentAmmo < magSize then gun.CurrentAmmo = magSize end
            if gun.Mag ~= nil and gun.Mag < magSize then gun.Mag = magSize end
            if gun.Clip ~= nil and gun.Clip < magSize then gun.Clip = magSize end
            if gun.AmmoInMag ~= nil and gun.AmmoInMag < magSize then gun.AmmoInMag = magSize end
            if gun.Bullets ~= nil and gun.Bullets < magSize then gun.Bullets = magSize end

            -- If there is stored ammo logic, keep it high too
            if gun.MaxAmmo ~= nil and gun.MaxAmmo < 9999 then gun.MaxAmmo = 9999 end
            if gun.StoredAmmo ~= nil and gun.StoredAmmo < 9999 then gun.StoredAmmo = 9999 end
        end)
    end
end

