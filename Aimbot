-- MAIN LOOP (Aimbot, Magnet, Trigger, Autoshoot, Flick)
------------------------------------------------------

local lastFrameTime   = tick()
local autoshootDown   = false
local lastTriggerTime = 0

RunService.RenderStepped:Connect(function()
    local now = tick()
    local dt  = now - lastFrameTime
    lastFrameTime = now

    local camera = Workspace.CurrentCamera
    if not camera then return end

    -- Should we be aiming this frame?
    local shouldAim
    if AimbotConfig.HoldToAim then
        shouldAim = holdingKey
    else
        shouldAim = toggleAimingActive
    end

    local currentTargetPart
    local currentTargetPlayer

    --------------------------------------------------
    -- AIMBOT (camera – cleaned feel)
    --------------------------------------------------
    if AimbotConfig.Enabled and shouldAim then
        currentTargetPlayer = getBestTarget(camera)
        if currentTargetPlayer and currentTargetPlayer.Character then
            local part = getTargetPart(currentTargetPlayer)
            if part and part:IsA("BasePart") then
                currentTargetPart = part

                local camCF     = camera.CFrame
                local camPos    = camCF.Position
                local targetPos = part.Position
                local toTarget  = targetPos - camPos

                if toTarget.Magnitude > 1 then
                    local desiredCF = CFrame.new(camPos, camPos + toTarget)

                    -- Base smoothing
                    local smooth = math.clamp(AimbotConfig.Smoothing or 0.35, 0.02, 1)
                    if AimbotConfig.Mode == "Rage" then
                        smooth = math.clamp(AimbotConfig.RageSmoothing or 0.05, 0.01, 0.4)
                    end

                    -- Optional angle snap (limits rotation per frame)
                    if AimbotConfig.AngleSnapEnabled then
                        local currentLook = camCF.LookVector
                        local desiredLook = toTarget.Unit
                        local dot = math.clamp(currentLook:Dot(desiredLook), -1, 1)
                        local angle = math.acos(dot)
                        local maxStep = math.rad(AimbotConfig.AngleSnapDegrees)

                        if angle > maxStep then
                            local axis = currentLook:Cross(desiredLook)
                            if axis.Magnitude > 0 then
                                axis = axis.Unit
                                local clampedCF = CFrame.fromAxisAngle(axis, math.min(angle, maxStep))
                                desiredCF = CFrame.new(camPos, camPos + (clampedCF * currentLook))
                            end
                        end
                    end

                    local step = math.clamp(smooth * dt * 90, 0, 1)
                    camera.CFrame = camCF:Lerp(desiredCF, step)
                end
            end
        end
    end

    --------------------------------------------------
    -- MAGNET AIM (mouse move toward nearest to crosshair)
    --------------------------------------------------
    if AimbotConfig.MagnetAim and mousemoverel then
        local magnetActive = shouldAim
        if magnetActive then
            local mousePos = UserInputService:GetMouseLocation()
            local bestPos
            local bestDist = math.huge
            local camPos = camera.CFrame.Position
            local viewport = camera.ViewportSize
            local screenCenter = Vector2.new(viewport.X / 2, viewport.Y / 2)

            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and isAlive(plr) then
                    if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                        continue
                    end

                    local part = getTargetPart(plr)
                    if part then
                        local worldPos = part.Position
                        if (worldPos - camPos).Magnitude <= AimbotConfig.MaxDistance then
                            local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                            if onScreen and screenPos.Z > 0 then
                                local target2D = Vector2.new(screenPos.X, screenPos.Y)
                                local distToCenter = (screenCenter - target2D).Magnitude
                                if distToCenter <= AimbotConfig.MagnetFOV then
                                    local diff = (target2D - mousePos).Magnitude
                                    if diff < bestDist then
                                        bestDist = diff
                                        bestPos = target2D
                                    end
                                end
                            end
                        end
                    end
                end
            end

            if bestPos then
                local diffVec = bestPos - mousePos
                local moveX = diffVec.X * AimbotConfig.MagnetStrength
                local moveY = diffVec.Y * AimbotConfig.MagnetStrength
                mousemoverel(moveX, moveY)
            end
        end
    end

    --------------------------------------------------
    -- AUTOSHOOT (aimbot target)
    --------------------------------------------------
    local wantShoot = false
    if AimbotConfig.AutoShoot
        and (not AimbotConfig.AutoShootWhileKey or shouldAim)
        and currentTargetPlayer and currentTargetPart
    then
        if isVisible(camera.CFrame.Position, currentTargetPart, {LocalPlayer.Character, camera}) then
            wantShoot = true
        end
    end

    if wantShoot and mouse1press and mouse1release then
        if not autoshootDown then
            autoshootDown = true
            pcall(function() mouse1press() end)
        end
    else
        if autoshootDown and mouse1release then
            autoshootDown = false
            pcall(function() mouse1release() end)
        end
    end

    --------------------------------------------------
    -- TRIGGERBOT (classic crosshair trigger)
    --------------------------------------------------
    if AimbotConfig.Triggerbot and mouse1press and mouse1release then
        local active = true
        if AimbotConfig.TriggerbotOnKey then
            active = shouldAim
        end

        if active then
            local mouseLoc = UserInputService:GetMouseLocation()
            local mousePos = Vector2.new(mouseLoc.X, mouseLoc.Y)
            local bestPlr, bestPart
            local bestMetric = math.huge
            local camPos = camera.CFrame.Position

            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and isAlive(plr) then
                    if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                        continue
                    end

                    local char = plr.Character
                    local part = getTargetPart(plr)
                    if part and char then
                        local worldPos = part.Position
                        if (worldPos - camPos).Magnitude <= AimbotConfig.MaxDistance then
                            local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                            if onScreen and screenPos.Z > 0 then
                                local target2D = Vector2.new(screenPos.X, screenPos.Y)
                                local box = getScreenBox(camera, char)

                                local inTrigger = false
                                local metric = math.huge

                                -- Bone-based radius check
                                local distToBone = (mousePos - target2D).Magnitude
                                if distToBone <= AimbotConfig.TriggerbotFOV then
                                    inTrigger = true
                                    metric = distToBone
                                end

                                -- Or inside the 2D box body
                                if box then
                                    local halfW = box.width / 2
                                    local halfH = box.height / 2
                                    local minX = box.center.X - halfW
                                    local maxX = box.center.X + halfW
                                    local minY = box.center.Y - halfH
                                    local maxY = box.center.Y + halfH

                                    if mousePos.X >= minX and mousePos.X <= maxX and mousePos.Y >= minY and mousePos.Y <= maxY then
                                        inTrigger = true
                                        local boxCenterDist = (mousePos - box.center).Magnitude
                                        metric = math.min(metric, boxCenterDist)
                                    end
                                end

                                if inTrigger then
                                    if isVisible(camPos, part, {LocalPlayer.Character, camera}) then
                                        if metric < bestMetric then
                                            bestMetric = metric
                                            bestPlr = plr
                                            bestPart = part
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end

            if bestPlr and bestPart then
                local delaySec = (AimbotConfig.TriggerbotDelayMs or 0) / 1000
                if now - lastTriggerTime >= delaySec then
                    lastTriggerTime = now
                    pcall(function() mouse1press() end)
                    pcall(function() mouse1release() end)
                end
            end
        end
    end

    --------------------------------------------------
    -- FLICK PATCHES
    --------------------------------------------------
    if MiscConfig.NoReload_Flick then
        if now - lastScanTime > scanInterval then
            lastScanTime = now
            scanFlickGuns()
        end
        applyFlickPatches()
    end

    --------------------------------------------------
    -- ESP UPDATE -- SKIPPED (Dinas handles ESP)
    --------------------------------------------------
end)

