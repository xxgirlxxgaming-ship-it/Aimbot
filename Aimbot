-- AIMBOT / ESP CORE LOGIC
------------------------------------------------------
local function isAlive(plr)
    if not plr.Character then return false end
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    return hum.Health > 0
end

local function getTargetPart(plr)
    local char = plr.Character
    if not char then return nil end

    -- Prefer selected target part exactly
    local selected = AimbotConfig.TargetPart
    local part = char:FindFirstChild(selected)
    if part and part:IsA("BasePart") then
        return part
    end

    -- Fallbacks
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp and hrp:IsA("BasePart") then
        return hrp
    end

    local head = char:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        return head
    end

    return nil
end

-- Raycast params cache for visibility check
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Blacklist

local function isVisible(fromPos, targetPart, ignoreList)
    if not AimbotConfig.VisibleCheck then
        return true
    end

    local dir = (targetPart.Position - fromPos)
    rayParams.FilterDescendantsInstances = ignoreList

    local result = Workspace:Raycast(fromPos, dir, rayParams)
    if not result then
        return true
    end

    -- hit the same character we're targeting => considered visible
    return result.Instance:IsDescendantOf(targetPart.Parent)
end

-- Cached sticky target
local stickyTargetPlayer = nil

-- Better target selection with priority + sticky
local function getBestTarget(camera)
    camera = camera or Workspace.CurrentCamera
    if not camera then return nil end

    local mouseLoc = UserInputService:GetMouseLocation()
    local mousePos = Vector2.new(mouseLoc.X, mouseLoc.Y)

    -- 1) If sticky target is enabled and still valid, keep it
    if AimbotConfig.StickyTarget and stickyTargetPlayer and isAlive(stickyTargetPlayer) then
        local part = getTargetPart(stickyTargetPlayer)
        if part then
            local worldPos = part.Position
            local dist3D = (worldPos - camera.CFrame.Position).Magnitude
            if dist3D <= AimbotConfig.MaxDistance then
                local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                if onScreen and screenPos.Z > 0 then
                    local target2D = Vector2.new(screenPos.X, screenPos.Y)
                    local crosshairDist = (mousePos - target2D).Magnitude

                    local effectiveFOV = AimbotConfig.FOVRadius
                    if AimbotConfig.DynamicFOV then
                        local scale = math.clamp(1 - (dist3D / (AimbotConfig.MaxDistance * 1.5)), 0.4, 1)
                        effectiveFOV = effectiveFOV * scale
                    end

                    if crosshairDist <= effectiveFOV then
                        if isVisible(camera.CFrame.Position, part, {LocalPlayer.Character, camera}) then
                            return stickyTargetPlayer
                        end
                    end
                end
            end
        end
    end

    -- 2) Normal search
    local bestPlayer
    local bestScore = math.huge

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and isAlive(plr) then
            local part = getTargetPart(plr)
            if part then
                local worldPos = part.Position
                local dist3D = (worldPos - camera.CFrame.Position).Magnitude

                if dist3D <= AimbotConfig.MaxDistance then
                    local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                    if onScreen and screenPos.Z > 0 then
                        local target2D = Vector2.new(screenPos.X, screenPos.Y)
                        local crosshairDist = (mousePos - target2D).Magnitude

                        local effectiveFOV = AimbotConfig.FOVRadius
                        if AimbotConfig.DynamicFOV then
                            local scale = math.clamp(1 - (dist3D / (AimbotConfig.MaxDistance * 1.5)), 0.4, 1)
                            effectiveFOV = effectiveFOV * scale
                        end

                        if crosshairDist <= effectiveFOV * 1.05 then -- slight margin
                            if isVisible(camera.CFrame.Position, part, {LocalPlayer.Character, camera}) then
                                local score
                                if AimbotConfig.PriorityMode == "Distance" then
                                    score = dist3D
                                else
                                    -- Crosshair priority + slight distance weight
                                    score = crosshairDist + (dist3D * 0.015)
                                end

                                if score < bestScore then
                                    bestScore = score
                                    bestPlayer = plr
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    if AimbotConfig.StickyTarget then
        stickyTargetPlayer = bestPlayer
    else
        stickyTargetPlayer = nil
    end

    return bestPlayer
end

