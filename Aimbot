-- TARGET SELECTION (CENTER-SCREEN)
------------------------------------------------------
local function getBestTarget(camera)
    local bestPlayer
    local bestMetric = math.huge

    local viewport = camera.ViewportSize
    local screenCenter = Vector2.new(viewport.X / 2, viewport.Y / 2)
    local camPos = camera.CFrame.Position

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and isAlive(plr) then
            local part = getTargetPart(plr)
            if part and part:IsA("BasePart") then
                local worldPos = part.Position
                local dist3D = (worldPos - camPos).Magnitude

                if dist3D <= AimbotConfig.MaxDistance then
                    local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                    if onScreen and screenPos.Z > 0 then
                        local target2D = Vector2.new(screenPos.X, screenPos.Y)
                        local crossDist = (screenCenter - target2D).Magnitude

                        local metric = crossDist * 3 + dist3D * 0.015

                        if AimbotConfig.VisibleCheck then
                            if not isVisible(camPos, part, {LocalPlayer.Character, camera}) then
                                metric = metric + 999999
                            end
                        end

                        if metric < bestMetric then
                            bestMetric = metric
                            bestPlayer = plr
                        end
                    end
                end
            end
        end
    end

    return bestPlayer
end

------------------------------------------------------
-- MAIN RENDERSTEPPED LOOP (AIMBOT, STICKY, TRIGGER, AUTOSHOOT, ESP, MISC)
------------------------------------------------------
local lastFrameTime   = tick()
local autoshootDown   = false
local lastTriggerTime = 0

RunService.RenderStepped:Connect(function()
    local now = tick()
    local dt  = now - lastFrameTime
    lastFrameTime = now

    local camera = Workspace.CurrentCamera
    if not camera then return end

    local shouldAim
    if AimbotConfig.HoldToAim then
        shouldAim = holdingKey
    else
        shouldAim = toggleAimingActive
    end

    local currentTargetPart
    local currentTargetPlayer

    --------------------------------------------------
    -- Aimbot aiming (CENTER SCREEN)
    --------------------------------------------------
    if AimbotConfig.Enabled and shouldAim then
        currentTargetPlayer = getBestTarget(camera)
        if currentTargetPlayer and currentTargetPlayer.Character then
            local part = getTargetPart(currentTargetPlayer)
            if part and part:IsA("BasePart") then
                currentTargetPart = part

                local targetPos = part.Position
                local camCF    = camera.CFrame
                local camPos   = camCF.Position
                local toTarget = (targetPos - camPos)

                if toTarget.Magnitude > 1 then
                    local desiredCF = CFrame.new(camPos, camPos + toTarget)

                    local smooth = math.clamp(AimbotConfig.Smoothing or 0.22, 0.02, 0.95)
                    local alpha  = math.clamp(smooth * dt * 95, 0, 1)

                    camera.CFrame = camCF:Lerp(desiredCF, alpha)
                end
            end
        end
    end

    --------------------------------------------------
    -- Sticky Aim (mouse pull near crosshair)
    --------------------------------------------------
    if AimbotConfig.Enabled and AimbotConfig.StickyAim and mousemoverel then
        if (AimbotConfig.HoldToAim and holdingKey) or (not AimbotConfig.HoldToAim and toggleAimingActive) then
            local mousePos = UserInputService:GetMouseLocation()
            local closest, closestDist

            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and isAlive(plr) then
                    if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                        continue
                    end

                    local part = getTargetPart(plr)
                    if part then
                        local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
                        if onScreen and screenPos.Z > 0 then
                            local diff = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                            if diff <= AimbotConfig.StickyRadius and (not closestDist or diff < closestDist) then
                                closest = screenPos
                                closestDist = diff
                            end
                        end
                    end
                end
            end

            if closest then
                local diffVec = Vector2.new(closest.X, closest.Y) - mousePos
                local moveX = diffVec.X * AimbotConfig.StickyStrength
                local moveY = diffVec.Y * AimbotConfig.StickyStrength
                mousemoverel(moveX, moveY)
            end
        end
    end

    --------------------------------------------------
    -- Autoshoot (uses current target)
    --------------------------------------------------
    local canAutoshoot = false
    if AimbotConfig.AutoShoot
        and (not AimbotConfig.AutoShootWhileKey or shouldAim)
        and currentTargetPlayer and currentTargetPart
    then
        if isVisible(camera.CFrame.Position, currentTargetPart, {LocalPlayer.Character, camera}) then
            canAutoshoot = true
        end
    end

    if canAutoshoot and mouse1press and mouse1release then
        if not autoshootDown then
            autoshootDown = true
            pcall(function() mouse1press() end)
        end
    else
        if autoshootDown and mouse1release then
            autoshootDown = false
            pcall(function() mouse1release() end)
        end
    end

    --------------------------------------------------
    -- Triggerbot (uses current target, with delay)
    --------------------------------------------------
    if AimbotConfig.Triggerbot and mouse1press and mouse1release and currentTargetPlayer and currentTargetPart then
        if isVisible(camera.CFrame.Position, currentTargetPart, {LocalPlayer.Character, camera}) then
            local mouseLoc = UserInputService:GetMouseLocation()
            local mousePos = Vector2.new(mouseLoc.X, mouseLoc.Y)
            local screenPos, onScreen = camera:WorldToViewportPoint(currentTargetPart.Position)

            if onScreen and screenPos.Z > 0 then
                local target2D = Vector2.new(screenPos.X, screenPos.Y)
                local distToCross = (mousePos - target2D).Magnitude

                local baseRadius = (camera.ViewportSize.X + camera.ViewportSize.Y) / 2
                local maxTriggerRadius = math.max(2, baseRadius * 0.008)

                if distToCross <= maxTriggerRadius then
                    local delaySec = (AimbotConfig.TriggerbotDelayMs or 0) / 1000
                    if now - lastTriggerTime >= delaySec then
                        lastTriggerTime = now
                        pcall(function() mouse1press() end)
                        pcall(function() mouse1release() end)
                    end
                end
            end
        end
    end

    --------------------------------------------------
    -- Apply Flick patches periodically while toggle on
    --------------------------------------------------
    if MiscConfig.NoReload_Flick then
        if now - lastScanTime > scanInterval then
            lastScanTime = now
            scanFlickGuns()
        end
        applyFlickPatches()
    end

    --------------------------------------------------
    -- ESP update (optimized)
    --------------------------------------------------
    if Drawing and ESPConfig.Enabled then
        local showBoxes = ESPConfig.ShowBoxes
        local showNames = ESPConfig.ShowNames
        local teamCheck = ESPConfig.TeamCheck and LocalPlayer.Team ~= nil

        for plr, data in pairs(ESPObjects) do
            local char = plr.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")

            if not (char and hum and hrp and hum.Health > 0) then
                if data.Box  then data.Box.Visible  = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            if teamCheck and plr.Team and LocalPlayer.Team == plr.Team then
                if data.Box  then data.Box.Visible  = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            local rootPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if not onScreen or rootPos.Z < 0 then
                if data.Box  then data.Box.Visible  = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            local head = char:FindFirstChild("Head")
            local leg  = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftLowerLeg") or char:FindFirstChild("LeftFoot")

            local topPos    = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or rootPos
            local bottomPos = leg and camera:WorldToViewportPoint(leg.Position - Vector3.new(0, 0.5, 0))
                or camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

            local height = math.abs(topPos.Y - bottomPos.Y)
            local width  = height / 2

            if data.Box then
                if showBoxes then
                    data.Box.Size     = Vector2.new(width, height)
                    data.Box.Position = Vector2.new(rootPos.X - width / 2, topPos.Y)
                    data.Box.Visible  = true
                else
                    data.Box.Visible = false
                end
            end

            if data.Name then
                if showNames then
                    data.Name.Text     = plr.Name
                    data.Name.Position = Vector2.new(rootPos.X, topPos.Y - 18)
                    data.Name.Visible  = true
                else
                    data.Name.Visible = false
                end
            end
        end
    elseif Drawing then
        -- If ESP disabled, hide everything without deleting
        for _, data in pairs(ESPObjects) do
            if data.Box  then data.Box.Visible  = false end
            if data.Name then data.Name.Visible = false end
        end
    end
end)

