-- SKELETON POINTS HELPER
------------------------------------------------------

local function getSkeletonPoints(char)
    if not char then return nil end

    local function gp(name)
        return char:FindFirstChild(name)
    end

    local head = gp("Head")
    local hrp  = gp("HumanoidRootPart")
    local ul   = gp("UpperTorso") or gp("Torso")
    local ll   = gp("LowerTorso")

    local lArmU = gp("LeftUpperArm") or gp("Left Arm")
    local lArmL = gp("LeftLowerArm")
    local lHand = gp("LeftHand") or gp("LeftHand")

    local rArmU = gp("RightUpperArm") or gp("Right Arm")
    local rArmL = gp("RightLowerArm")
    local rHand = gp("RightHand")

    local lLegU = gp("LeftUpperLeg") or gp("Left Leg")
    local lLegL = gp("LeftLowerLeg")
    local lFoot = gp("LeftFoot")

    local rLegU = gp("RightUpperLeg") or gp("Right Leg")
    local rLegL = gp("RightLowerLeg")
    local rFoot = gp("RightFoot")

    return {
        Head = head,
        Root = hrp,
        UpperTorso = ul,
        LowerTorso = ll,

        LeftUpperArm  = lArmU,
        LeftLowerArm  = lArmL,
        LeftHand      = lHand,
        RightUpperArm = rArmU,
        RightLowerArm = rArmL,
        RightHand     = rHand,

        LeftUpperLeg  = lLegU,
        LeftLowerLeg  = lLegL,
        LeftFoot      = lFoot,
        RightUpperLeg = rLegU,
        RightLowerLeg = rLegL,
        RightFoot     = rFoot,
    }
end

local function ensureLine(list, key)
    if not list[key] and Drawing then
        local ln = Drawing.new("Line")
        ln.Thickness = 1
        ln.Color     = ESPConfig.Color_Skeleton
        list[key]    = ln
    end
    return list[key]
end

------------------------------------------------------
-- ESP UPDATE LOOP
------------------------------------------------------

local function updateESP()
    if not Drawing then return end

    for plr, esp in pairs(ESPObjects) do
        local char = plr.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")

        esp.Character = char
        esp.Humanoid  = hum
        esp.RootPart  = hrp

        local isValid = ESPConfig.Enabled and plr ~= LocalPlayer and char and hum and hum.Health > 0 and hrp
        if isValid then
            if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                isValid = false
            end
        end

        if not isValid then
            if esp.Box then esp.Box.Visible = false end
            if esp.Tracer then esp.Tracer.Visible = false end
            if esp.Name then esp.Name.Visible = false end
            if esp.Dist then esp.Dist.Visible = false end
            if esp.HeadDot then esp.HeadDot.Visible = false end
            if esp.ViewLine then esp.ViewLine.Visible = false end
            clearSkeleton(esp)
            clearChams(esp)
            continue
        end

        local rootPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
        if not onScreen or rootPos.Z <= 0 then
            if esp.Box then esp.Box.Visible = false end
            if esp.Tracer then esp.Tracer.Visible = false end
            if esp.Name then esp.Name.Visible = false end
            if esp.Dist then esp.Dist.Visible = false end
            if esp.HeadDot then esp.HeadDot.Visible = false end
            if esp.ViewLine then esp.ViewLine.Visible = false end
            clearSkeleton(esp)
            clearChams(esp)
            continue
        end

        local box = getScreenBox(camera, char)
        local distance = (hrp.Position - camera.CFrame.Position).Magnitude

        -- Box
        if esp.Box and ESPConfig.Boxes and box then
            esp.Box.Size     = Vector2.new(box.width, box.height)
            esp.Box.Position = Vector2.new(box.center.X - box.width/2, box.center.Y - box.height/2)
            esp.Box.Color    = ESPConfig.Color_Box
            esp.Box.Visible  = true
        elseif esp.Box then
            esp.Box.Visible = false
        end

        -- Tracers from screen
        if esp.Tracer and ESPConfig.Tracers then
            local viewport = camera.ViewportSize
            local origin
            if ESPConfig.TracerOrigin == "Top" then
                origin = Vector2.new(viewport.X/2, 0)
            elseif ESPConfig.TracerOrigin == "Center" then
                origin = Vector2.new(viewport.X/2, viewport.Y/2)
            else
                origin = Vector2.new(viewport.X/2, viewport.Y)
            end

            esp.Tracer.From    = origin
            esp.Tracer.To      = Vector2.new(rootPos.X, rootPos.Y)
            esp.Tracer.Color   = ESPConfig.Color_Tracer
            esp.Tracer.Visible = true
        elseif esp.Tracer then
            esp.Tracer.Visible = false
        end

        -- View tracers from enemy head
        if esp.ViewLine and ESPConfig.ViewTracers and head then
            local headPos, headOn = camera:WorldToViewportPoint(head.Position)
            local lookDir = head.CFrame.LookVector
            local endWorld = head.Position + (lookDir * 10)
            local endPos, endOn = camera:WorldToViewportPoint(endWorld)
            if headOn and endOn then
                esp.ViewLine.From    = Vector2.new(headPos.X, headPos.Y)
                esp.ViewLine.To      = Vector2.new(endPos.X, endPos.Y)
                esp.ViewLine.Color   = ESPConfig.Color_Tracer
                esp.ViewLine.Visible = true
            else
                esp.ViewLine.Visible = false
            end
        elseif esp.ViewLine then
            esp.ViewLine.Visible = false
        end

        -- Name
        if esp.Name and ESPConfig.Names then
            esp.Name.Text     = plr.Name
            esp.Name.Position = Vector2.new(rootPos.X, rootPos.Y - (box and box.height/2 + 12 or 20))
            esp.Name.Color    = ESPConfig.Color_Main
            esp.Name.Visible  = true
        elseif esp.Name then
            esp.Name.Visible = false
        end

        -- Distance
        if esp.Dist and ESPConfig.Distance then
            esp.Dist.Text     = string.format("%.0f studs", distance)
            esp.Dist.Position = Vector2.new(rootPos.X, rootPos.Y + (box and box.height/2 + 12 or 20))
            esp.Dist.Color    = ESPConfig.Color_Main
            esp.Dist.Visible  = true
        elseif esp.Dist then
            esp.Dist.Visible = false
        end

        -- Head dot
        if esp.HeadDot and ESPConfig.HeadDot and head then
            local headPos, headOnScreen = camera:WorldToViewportPoint(head.Position)
            if headOnScreen and headPos.Z > 0 then
                esp.HeadDot.Position = Vector2.new(headPos.X, headPos.Y)
                esp.HeadDot.Color    = ESPConfig.Color_HeadDot
                esp.HeadDot.Visible  = true
            else
                esp.HeadDot.Visible  = false
            end
        elseif esp.HeadDot then
            esp.HeadDot.Visible = false
        end

        -- Skeleton
        clearSkeleton(esp) -- rebuild each frame (safer for R15/R6 mix, still light)
        if ESPConfig.Skeleton then
            local points = getSkeletonPoints(char)
            if points and points.Head and points.UpperTorso and points.Root then
                local function worldToVec3(part)
                    local p, vis = camera:WorldToViewportPoint(part.Position)
                    if not vis or p.Z <= 0 then return nil end
                    return Vector2.new(p.X, p.Y)
                end

                local function drawBone(aName, bName, key)
                    local a = points[aName]
                    local b = points[bName]
                    if a and b then
                        local a2 = worldToVec3(a)
                        local b2 = worldToVec3(b)
                        if a2 and b2 then
                            local line = ensureLine(esp.SkeletonLines, key)
                            if line then
                                line.From    = a2
                                line.To      = b2
                                line.Color   = ESPConfig.Color_Skeleton
                                line.Visible = true
                            end
                        end
                    end
                end

                -- torso
                drawBone("Head", "UpperTorso", "Head_UT")
                if points.LowerTorso then
                    drawBone("UpperTorso", "LowerTorso", "UT_LT")
                    drawBone("LowerTorso", "Root", "LT_Root")
                else
                    drawBone("UpperTorso", "Root", "UT_Root")
                end

                -- arms
                drawBone("UpperTorso", "LeftUpperArm", "UT_LUA")
                drawBone("LeftUpperArm", "LeftLowerArm", "LUA_LLA")
                drawBone("LeftLowerArm", "LeftHand", "LLA_LH")

                drawBone("UpperTorso", "RightUpperArm", "UT_RUA")
                drawBone("RightUpperArm", "RightLowerArm", "RUA_RLA")
                drawBone("RightLowerArm", "RightHand", "RLA_RH")

                -- legs
                drawBone("Root", "LeftUpperLeg", "Root_LUL")
                drawBone("LeftUpperLeg", "LeftLowerLeg", "LUL_LLL")
                drawBone("LeftLowerLeg", "LeftFoot", "LLL_LF")

                drawBone("Root", "RightUpperLeg", "Root_RUL")
                drawBone("RightUpperLeg", "RightLowerLeg", "RUL_RLL")
                drawBone("RightLowerLeg", "RightFoot", "RLL_RF")
            end
        end

        -- Chams 3D (simple Highlight)
        clearChams(esp)
        if ESPConfig.Chams3D and char then
            local highlight = Instance.new("Highlight")
            highlight.Adornee = char
            highlight.FillColor = ESPConfig.Color_Chams
            highlight.OutlineColor = ESPConfig.Color_Chams
            highlight.FillTransparency = ESPConfig.ChamsTransparency
            highlight.OutlineTransparency = math.clamp(ESPConfig.ChamsTransparency + 0.2, 0, 1)
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Parent = char
            table.insert(esp.ChamsParts, highlight)
        end
    end
end

------------------------------------------------------
-- MAIN LOOP (Aimbot, Magnet, Trigger, Autoshoot, ESP)
------------------------------------------------------

local lastFrameTime   = tick()
local autoshootDown   = false
local lastTriggerTime = 0

RunService.RenderStepped:Connect(function()
    local now = tick()
    local dt  = now - lastFrameTime
    lastFrameTime = now

    camera = Workspace.CurrentCamera or camera
    if not camera then return end

    -- Should we be aiming this frame?
    local shouldAim
    if AimbotConfig.HoldToAim then
        shouldAim = holdingKey
    else
        shouldAim = toggleAimingActive
    end

    local currentTargetPart
    local currentTargetPlayer

    --------------------------------------------------
    -- AIMBOT (hyper-precise, flick-capable)
    --------------------------------------------------
    if AimbotConfig.Enabled and shouldAim then
        currentTargetPlayer = getBestTarget(camera)
        if currentTargetPlayer and currentTargetPlayer.Character then
            -- small vertical prediction for jumping (aim a bit above bone)
            local part = getTargetPart(currentTargetPlayer)
            if part and part:IsA("BasePart") then
                local char = currentTargetPlayer.Character
                local hum  = char and char:FindFirstChildOfClass("Humanoid")
                local predictedOffset = Vector3.new(0, 0, 0)
                if hum and hum.MoveDirection.Magnitude > 0 then
                    local vel = char:FindFirstChild("HumanoidRootPart") and char.HumanoidRootPart.Velocity or Vector3.zero
                    predictedOffset = Vector3.new(0, vel.Y * 0.015, 0) -- light vertical lead
                end

                currentTargetPart = part

                local camCF     = camera.CFrame
                local camPos    = camCF.Position
                local targetPos = part.Position + predictedOffset
                local toTarget  = targetPos - camPos

                if toTarget.Magnitude > 1 then
                    local desiredCF = CFrame.new(camPos, camPos + toTarget)

                    -- Very low smoothing for almost-instant flick
                    local smooth = math.clamp(AimbotConfig.Smoothing or 0.01, 0.005, 1)

                    -- Optional angle snap (limits rotation per frame, high cap -> fast flicks)
                    if AimbotConfig.AngleSnapEnabled then
                        local currentLook = camCF.LookVector
                        local desiredLook = toTarget.Unit
                        local dot = math.clamp(currentLook:Dot(desiredLook), -1, 1)
                        local angle = math.acos(dot)
                        local maxStep = math.rad(AimbotConfig.AngleSnapDegrees or 60)

                        if angle > maxStep then
                            local axis = currentLook:Cross(desiredLook)
                            if axis.Magnitude > 0 then
                                axis = axis.Unit
                                local clampedCF = CFrame.fromAxisAngle(axis, math.min(angle, maxStep))
                                desiredCF = CFrame.new(camPos, camPos + (clampedCF * currentLook))
                            end
                        end
                    end

                    local step = math.clamp(smooth * dt * 200, 0, 1)
                    camera.CFrame = camCF:Lerp(desiredCF, step)
                end
            end
        end
    end

    --------------------------------------------------
    -- MAGNET AIM (mouse move toward nearest to crosshair)
    --------------------------------------------------
    if AimbotConfig.MagnetAim and mousemoverel then
        local magnetActive = shouldAim
        if magnetActive then
            local mousePos = UserInputService:GetMouseLocation()
            local bestPos
            local bestDist = math.huge
            local camPos = camera.CFrame.Position
            local viewport = camera.ViewportSize
            local screenCenter = Vector2.new(viewport.X / 2, viewport.Y / 2)

            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and isAlive(plr) then
                    if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                        continue
                    end

                    local part = getTargetPart(plr)
                    if part then
                        local worldPos = part.Position
                        if (worldPos - camPos).Magnitude <= AimbotConfig.MaxDistance then
                            local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                            if onScreen and screenPos.Z > 0 then
                                local target2D = Vector2.new(screenPos.X, screenPos.Y)
                                local distToCenter = (screenCenter - target2D).Magnitude
                                if distToCenter <= AimbotConfig.MagnetFOV then
                                    local diff = (target2D - mousePos).Magnitude
                                    if diff < bestDist then
                                        bestDist = diff
                                        bestPos = target2D
                                    end
                                end
                            end
                        end
                    end
                end
            end

            if bestPos then
                local diffVec = bestPos - mousePos
                local moveX = diffVec.X * AimbotConfig.MagnetStrength
                local moveY = diffVec.Y * AimbotConfig.MagnetStrength
                mousemoverel(moveX, moveY)
            end
        end
    end

    --------------------------------------------------
    -- AUTOSHOOT (aimbot target)
    --------------------------------------------------
    local wantShoot = false
    if AimbotConfig.AutoShoot
        and (not AimbotConfig.AutoShootWhileKey or shouldAim)
        and currentTargetPlayer and currentTargetPart
    then
        if isVisible(camera.CFrame.Position, currentTargetPart, {LocalPlayer.Character, camera}) then
            wantShoot = true
        end
    end

    if wantShoot and mouse1press and mouse1release then
        if not autoshootDown then
            autoshootDown = true
            pcall(function() mouse1press() end)
        end
    else
        if autoshootDown and mouse1release then
            autoshootDown = false
            pcall(function() mouse1release() end)
        end
    end

    --------------------------------------------------
    -- TRIGGERBOT (classic crosshair trigger)
    --------------------------------------------------
    if AimbotConfig.Triggerbot and mouse1press and mouse1release then
        local active = true
        if AimbotConfig.TriggerbotOnKey then
            active = shouldAim
        end

        if active then
            local mouseLoc = UserInputService:GetMouseLocation()
            local mousePos = Vector2.new(mouseLoc.X, mouseLoc.Y)
            local bestPlr, bestPart
            local bestMetric = math.huge
            local camPos = camera.CFrame.Position

            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and isAlive(plr) then
                    if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                        continue
                    end

                    local char = plr.Character
                    local part = getTargetPart(plr)
                    if part and char then
                        local worldPos = part.Position
                        if (worldPos - camPos).Magnitude <= AimbotConfig.MaxDistance then
                            local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                            if onScreen and screenPos.Z > 0 then
                                local target2D = Vector2.new(screenPos.X, screenPos.Y)
                                local box = getScreenBox(camera, char)

                                local inTrigger = false
                                local metric = math.huge

                                local distToBone = (mousePos - target2D).Magnitude
                                if distToBone <= AimbotConfig.TriggerbotFOV then
                                    inTrigger = true
                                    metric = distToBone
                                end

                                if box then
                                    local halfW = box.width / 2
                                    local halfH = box.height / 2
                                    local minX = box.center.X - halfW
                                    local maxX = box.center.X + halfW
                                    local minY = box.center.Y - halfH
                                    local maxY = box.center.Y + halfH

                                    if mousePos.X >= minX and mousePos.X <= maxX and mousePos.Y >= minY and mousePos.Y <= maxY then
                                        inTrigger = true
                                        local boxCenterDist = (mousePos - box.center).Magnitude
                                        metric = math.min(metric, boxCenterDist)
                                    end
                                end

                                if inTrigger then
                                    if isVisible(camPos, part, {LocalPlayer.Character, camera}) then
                                        if metric < bestMetric then
                                            bestMetric = metric
                                            bestPlr = plr
                                            bestPart = part
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end

            if bestPlr and bestPart then
                local delaySec = (AimbotConfig.TriggerbotDelayMs or 0) / 1000
                if now - lastTriggerTime >= delaySec then
                    lastTriggerTime = now
                    pcall(function() mouse1press() end)
                    pcall(function() mouse1release() end)
                end
            end
        end
    end

    --------------------------------------------------
    -- ESP UPDATE
    --------------------------------------------------
    updateESP()
end)

