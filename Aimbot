local camera = Workspace.CurrentCamera
local Drawing = Drawing or nil -- executor-provided Drawing API

local ESPObjects = {}

local function createESPObject(plr)
    local esp = {
        Player   = plr,
        Character= nil,
        Humanoid = nil,
        RootPart = nil,

        Box      = Drawing and Drawing.new("Square") or nil,
        Tracer   = Drawing and Drawing.new("Line") or nil,
        Name     = Drawing and Drawing.new("Text") or nil,
        Dist     = Drawing and Drawing.new("Text") or nil,
        HeadDot  = Drawing and Drawing.new("Circle") or nil,
        ViewLine = Drawing and Drawing.new("Line") or nil,

        SkeletonLines = {}, -- table of Line objects
        ChamsParts    = {}, -- Highlight instances
    }

    if esp.Box then
        esp.Box.Thickness = 1.5
        esp.Box.Filled    = false
        esp.Box.Color     = ESPConfig.Color_Box
    end

    if esp.Tracer then
        esp.Tracer.Thickness = 1
        esp.Tracer.Color     = ESPConfig.Color_Tracer
    end

    if esp.ViewLine then
        esp.ViewLine.Thickness = 1
        esp.ViewLine.Color     = ESPConfig.Color_Tracer
    end

    if esp.Name then
        esp.Name.Size   = 13
        esp.Name.Center = true
        esp.Name.Color  = ESPConfig.Color_Main
        esp.Name.Outline = true
    end

    if esp.Dist then
        esp.Dist.Size   = 12
        esp.Dist.Center = true
        esp.Dist.Color  = ESPConfig.Color_Main
        esp.Dist.Outline = true
    end

    if esp.HeadDot then
        esp.HeadDot.Filled = true
        esp.HeadDot.Radius = 3
        esp.HeadDot.Color  = ESPConfig.Color_HeadDot
    end

    ESPObjects[plr] = esp
end

local function clearSkeleton(esp)
    if not esp.SkeletonLines then return end
    for _, line in pairs(esp.SkeletonLines) do
        if typeof(line) == "userdata" and line.Remove then
            pcall(function() line:Remove() end)
        end
    end
    esp.SkeletonLines = {}
end

local function clearChams(esp)
    if not esp.ChamsParts then return end
    for _, h in pairs(esp.ChamsParts) do
        if typeof(h) == "Instance" then
            pcall(function() h:Destroy() end)
        end
    end
    esp.ChamsParts = {}
end

local function removeESPObject(plr)
    local esp = ESPObjects[plr]
    if not esp then return end

    clearSkeleton(esp)
    clearChams(esp)

    for _, obj in pairs(esp) do
        if typeof(obj) == "userdata" and obj.Remove then
            pcall(function() obj:Remove() end)
        end
    end

    ESPObjects[plr] = nil
end

for _, plr in ipairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then
        createESPObject(plr)
    end
end

Players.PlayerAdded:Connect(function(plr)
    if plr ~= LocalPlayer then
        createESPObject(plr)
    end
end)

Players.PlayerRemoving:Connect(function(plr)
    removeESPObject(plr)
end)

