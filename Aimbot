-- Main RenderStepped Loop (Aimbot + FOV + ESP + sliders)
------------------------------------------------------
local lastFrameTime = tick()

RunService.RenderStepped:Connect(function()
    local now = tick()
    local dt = now - lastFrameTime
    lastFrameTime = now

    local camera = Workspace.CurrentCamera
    if not camera then return end

    -- Update sliders while dragging
    if draggingFOV then
        local mousePos = UserInputService:GetMouseLocation().X
        local absPos = FOVSliderBack.AbsolutePosition.X
        local absSize = FOVSliderBack.AbsoluteSize.X
        local ratio = math.clamp((mousePos - absPos) / absSize, 0, 1)
        AimbotConfig.FOVRadius = math.clamp(math.floor(ratio * 900), 40, 900)
        updateFOVLabelAndBar()
    end

    if draggingSmooth then
        local mousePos = UserInputService:GetMouseLocation().X
        local absPos = SmoothBack.AbsolutePosition.X
        local absSize = SmoothBack.AbsoluteSize.X
        local ratio = math.clamp((mousePos - absPos) / absSize, 0.02, 1)
        AimbotConfig.Smoothing = ratio
        updateSmoothLabelAndBar()
    end

    if draggingPred then
        local mousePos = UserInputService:GetMouseLocation().X
        local absPos = PredBack.AbsolutePosition.X
        local absSize = PredBack.AbsoluteSize.X
        local ratio = math.clamp((mousePos - absPos) / absSize, 0, 1)
        AimbotConfig.PredictionStrength = math.clamp(ratio * 0.35, 0.01, 0.35)
        updatePredLabelAndBar()
    end

    -- Draw FOV circle
    if circle then
        circle.Visible = AimbotConfig.Enabled and AimbotConfig.DrawFOV
        if circle.Visible then
            local mouseLoc = UserInputService:GetMouseLocation()
            circle.Position = mouseLoc
            circle.Radius = AimbotConfig.FOVRadius
        end
    end

    -- Aimbot aiming
    if AimbotConfig.Enabled and holdingKey then
        local targetPlayer = getClosestPlayerToMouse()
        if targetPlayer and targetPlayer.Character then
            local part = getTargetPart(targetPlayer)
            if part then
                local targetPos = part.Position

                -- Simple velocity-based prediction
                if AimbotConfig.Prediction then
                    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        local vel = root.Velocity
                        targetPos = targetPos + (vel * AimbotConfig.PredictionStrength)
                    end
                end

                local camCF = camera.CFrame
                local toTarget = (targetPos - camCF.Position)
                if toTarget.Magnitude > 1 then
                    local desiredCF = CFrame.new(camCF.Position, camCF.Position + toTarget)

                    -- Convert smoothing (0.02–1) to rotation speed
                    local speed = math.clamp(AimbotConfig.Smoothing, 0.02, 1)
                    local alpha = math.clamp(speed * dt * 60, 0, 1) -- frame-rate independent

                    -- Tiny deadzone to reduce jitter when already on target
                    local angleDiff = (camCF.LookVector:Dot(toTarget.Unit))
                    if angleDiff < 0.999 then
                        camera.CFrame = camCF:Lerp(desiredCF, alpha)
                    end
                end
            end
        end
    end

    -- ESP update
    if Drawing and ESPConfig.Enabled then
        for plr, data in pairs(ESPObjects) do
            local char = plr.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if not (char and hum and hrp and hum.Health > 0) then
                if data.Box then data.Box.Visible = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                if data.Box then data.Box.Visible = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            local rootPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if not onScreen or rootPos.Z < 0 then
                if data.Box then data.Box.Visible = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            local head = char:FindFirstChild("Head")
            local leg = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftLowerLeg") or char:FindFirstChild("LeftFoot")

            local topPos = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or rootPos
            local bottomPos = leg and camera:WorldToViewportPoint(leg.Position - Vector3.new(0, 0.5, 0)) or camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

            local height = math.abs(topPos.Y - bottomPos.Y)
            local width = height / 2

            if data.Box and ESPConfig.ShowBoxes then
                data.Box.Size = Vector2.new(width, height)
                data.Box.Position = Vector2.new(rootPos.X - width / 2, topPos.Y)
                data.Box.Visible = true
            elseif data.Box then
                data.Box.Visible = false
            end

            if data.Name and ESPConfig.ShowNames then
                data.Name.Text = plr.Name
                data.Name.Position = Vector2.new(rootPos.X, topPos.Y - 18)
                data.Name.Visible = true
            elseif data.Name then
                data.Name.Visible = false
            end
        end
    elseif Drawing then
        -- hide ESP when disabled
        for _, data in pairs(ESPObjects) do
            if data.Box then data.Box.Visible = false end
            if data.Name then data.Name.Visible = false end
        end
    end
end)

