local function ApplyAimbotMode()
    if AimbotConfig.Mode == "Rage" then
        AimbotConfig.FOVRadius    = 360
        AimbotConfig.Smoothing    = 0.15 -- very snappy
        AimbotConfig.VisibleCheck = false
        AimbotConfig.AutoShoot    = true
        AimbotConfig.DynamicFOV   = true

    elseif AimbotConfig.Mode == "Legit" then
        AimbotConfig.FOVRadius    = 80
        AimbotConfig.Smoothing    = 0.45 -- smoother
        AimbotConfig.VisibleCheck = true
        AimbotConfig.AutoShoot    = false
        AimbotConfig.DynamicFOV   = false

    elseif AimbotConfig.Mode == "Custom" then
        -- Do not override anything, user controls all values manually
        return
    end

    print("[FrostHub DEBUG] Mode applied:", AimbotConfig.Mode, "FOV=", AimbotConfig.FOVRadius, "Smooth=", AimbotConfig.Smoothing)
end

-- Apply initial mode once
