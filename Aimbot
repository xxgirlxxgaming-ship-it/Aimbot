rayParams.FilterType = Enum.RaycastFilterType.Blacklist

local function isVisible(fromPos, targetPart, ignoreList)
    if not AimbotConfig.VisibleCheck then
        return true
    end

    if not targetPart or not targetPart.Parent then
        return false
    end

    local dir = (targetPart.Position - fromPos)
    rayParams.FilterDescendantsInstances = ignoreList

    local result = Workspace:Raycast(fromPos, dir, rayParams)
    if not result then
        return true
    end

    if AimbotConfig.AutoWall then
        if (result.Position - targetPart.Position).Magnitude <= 3 then
            return true
        end
    end

    return result.Instance:IsDescendantOf(targetPart.Parent)
end

------------------------------------------------------
-- TARGET SELECTION (FOV/Distance/Nearest)
------------------------------------------------------

local function getBestTarget(camera)
    local bestPlayer
    local bestScore = math.huge

    local viewport     = camera.ViewportSize
    local screenCenter = Vector2.new(viewport.X / 2, viewport.Y / 2)
    local camPos       = camera.CFrame.Position

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and isAlive(plr) then
            if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                continue
            end

            local char = plr.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            local part = getTargetPart(plr)
            if part and part:IsA("BasePart") and hum and hum.Health > 0 then
                local worldPos = part.Position
                local dist3D = (worldPos - camPos).Magnitude
                if dist3D <= AimbotConfig.MaxDistance then
                    local screenPos, onScreen = camera:WorldToViewportPoint(worldPos)
                    if onScreen and screenPos.Z > 0 then
                        local target2D = Vector2.new(screenPos.X, screenPos.Y)
                        local fovDist  = (screenCenter - target2D).Magnitude

                        if fovDist <= AimbotConfig.FOVRadius then
                            local visible = isVisible(camPos, part, {LocalPlayer.Character, camera})
                            if not visible then
                                if not AimbotConfig.AutoWall then
                                    continue
                                else
                                    dist3D = dist3D * 1.6
                                end
                            end

                            local score
                            if AimbotConfig.Priority == "Distance" then
                                score = dist3D
                            elseif AimbotConfig.Priority == "Nearest" then
                                score = dist3D * 0.5 + fovDist * 0.5
                            else -- FOV priority
                                score = fovDist * 1.5 + dist3D * 0.02
                            end

                            if score < bestScore then
                                bestScore = score
                                bestPlayer = plr
                            end
                        end
                    end
                end
            end
        end
    end

    return bestPlayer
end

------------------------------------------------------
-- HELPER: get screen-space box for trigger & ESP
------------------------------------------------------

local function getScreenBox(camera, char)
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local head = char:FindFirstChild("Head")
    local leg  = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftLowerLeg") or char:FindFirstChild("LeftFoot")

    local rootPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
    if not onScreen or rootPos.Z < 0 then return nil end

    local topPos    = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or rootPos
    local bottomPos = leg and camera:WorldToViewportPoint(leg.Position - Vector3.new(0, 0.5, 0))
        or camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

    local height = math.abs(topPos.Y - bottomPos.Y)
    local width  = height / 2

    return {
        center = Vector2.new(rootPos.X, (topPos.Y + bottomPos.Y) / 2),
        top    = Vector2.new(rootPos.X, topPos.Y),
        height = height,
        width  = width,
    }
end

