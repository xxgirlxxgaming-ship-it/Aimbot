local function createTabButton(name)
    local btn = Instance.new("TextButton")
    btn.Name = name .. "TabButton"
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(25, 35, 60)
    btn.AutoButtonColor = false
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 18
    btn.TextColor3 = Color3.fromRGB(190, 215, 255)
    btn.Text = name

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = btn

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(80, 140, 220)
    stroke.Thickness = 1
    stroke.Transparency = 0.5
    stroke.Parent = btn

    btn.Parent = TabColumn
    print("[FrostHub DEBUG] Tab button created:", name)
    return btn
end

local function createPage(name)
    local frame = Instance.new("Frame")
    frame.Name = name .. "Page"
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(16, 24, 42)
    frame.BorderSizePixel = 0
    frame.Visible = false

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = frame

    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 16)
    padding.PaddingLeft = UDim.new(0, 20)
    padding.PaddingRight = UDim.new(0, 20)
    padding.PaddingBottom = UDim.new(0, 16)
    padding.Parent = frame

    frame.Parent = PagesFolder
    print("[FrostHub DEBUG] Page created:", name .. "Page")
    return frame
end

local CurrentPage

local function showPage(name)
    print("[FrostHub DEBUG] showPage called with:", name)
    for _, child in ipairs(PagesFolder:GetChildren()) do
        if child:IsA("Frame") then
            child.Visible = (child.Name == name .. "Page")
        end
    end
    for _, btn in ipairs(TabColumn:GetChildren()) do
        if btn:IsA("TextButton") then
            if btn.Name == name .. "TabButton" then
                btn.BackgroundColor3 = Color3.fromRGB(35, 55, 90)
            else
                btn.BackgroundColor3 = Color3.fromRGB(25, 35, 60)
            end
        end
    end
    CurrentPage = name
end

