local function ApplyAimbotMode()
    if AimbotConfig.Mode == "Rage" then
        -- Very aggressive, very accurate
        AimbotConfig.Smoothing         = 0.08  -- extremely snappy
        AimbotConfig.VisibleCheck      = false -- can lock through walls client-side
        AimbotConfig.AutoShoot         = true
        AimbotConfig.AutoShootWhileKey = false
        AimbotConfig.MaxDistance       = 2600

    elseif AimbotConfig.Mode == "Legit" then
        -- Human-ish but still strong
        AimbotConfig.Smoothing         = 0.22
        AimbotConfig.VisibleCheck      = true
        AimbotConfig.AutoShoot         = false
        AimbotConfig.AutoShootWhileKey = true
        AimbotConfig.MaxDistance       = 1500

    elseif AimbotConfig.Mode == "Custom" then
        -- Do not override anything, user controls all values manually
        return
    end

    print("[FrostHub DEBUG] Mode applied:", AimbotConfig.Mode,
        "MaxDist=", AimbotConfig.MaxDistance,
        "Smooth=", AimbotConfig.Smoothing,
        "Vis=", AimbotConfig.VisibleCheck,
        "AutoShoot=", AimbotConfig.AutoShoot
    )
end

