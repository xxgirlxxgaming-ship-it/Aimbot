local ESPObjects = {}

local function createESPForPlayer(plr)
    if plr == LocalPlayer then return end

    ESPObjects[plr] = ESPObjects[plr] or {}
    local data = ESPObjects[plr]

    if Drawing then
        if not data.Box then
            local box = Drawing.new("Square")
            box.Color = Color3.fromRGB(0, 170, 255)
            box.Thickness = 1.5
            box.Filled = false
            box.Visible = false
            data.Box = box
        end

        if not data.Name then
            local name = Drawing.new("Text")
            name.Color = Color3.fromRGB(255, 255, 255)
            name.Size = 16
            name.Outline = true
            name.Center = true
            name.Visible = false
            data.Name = name
        end
    end
end

local function removeESPForPlayer(plr)
    local data = ESPObjects[plr]
    if not data then return end

    if data.Box then pcall(function() data.Box:Remove() end) end
    if data.Name then pcall(function() data.Name:Remove() end) end
    ESPObjects[plr] = nil
end

for _, plr in ipairs(Players:GetPlayers()) do
    createESPForPlayer(plr)
end

Players.PlayerAdded:Connect(createESPForPlayer)
Players.PlayerRemoving:Connect(removeESPForPlayer)

------------------------------------------------------
-- MAIN RENDERSTEPPED LOOP (AIMBOT, TRIGGERBOT, AUTOSHOOT, NOCLIP, ESP)
------------------------------------------------------
local lastFrameTime   = tick()
local autoshootDown   = false
local lastTriggerTime = 0

RunService.RenderStepped:Connect(function()
    local now = tick()
    local dt  = now - lastFrameTime
    lastFrameTime = now

    local camera = Workspace.CurrentCamera
    if not camera then return end

    -- decide if we should aim this frame
    local shouldAim
    if AimbotConfig.HoldToAim then
        shouldAim = holdingKey
    else
        shouldAim = toggleAimingActive
    end

    local currentTargetPart
    local currentTargetPlayer

    --------------------------------------------------
    -- Aimbot aiming (legit or instant flick) with optional prediction
    --------------------------------------------------
    if AimbotConfig.Enabled and shouldAim then
        currentTargetPlayer = getBestTarget(camera)
        if currentTargetPlayer and currentTargetPlayer.Character then
            local part = getTargetPart(currentTargetPlayer)
            if part then
                currentTargetPart = part

                local targetPos = part.Position

                -- Simple velocity-based prediction with fixed time ahead
                if AimbotConfig.Prediction then
                    local root = currentTargetPlayer.Character:FindFirstChild("HumanoidRootPart") or part
                    if root and root:IsA("BasePart") then
                        local vel = root.Velocity
                        local leadTime = 0.12 * (AimbotConfig.PredictionMultiplier or 1) -- ~120ms lead
                        targetPos = targetPos + (vel * leadTime)
                    end
                end

                local camCF = camera.CFrame
                local camPos = camCF.Position
                local toTarget = (targetPos - camPos)

                if toTarget.Magnitude > 1 then
                    local desiredCF = CFrame.new(camPos, camPos + toTarget)

                    if AimbotConfig.InstantFlick then
                        -- Rage-style instant snap
                        camera.CFrame = desiredCF
                    else
                        -- Smooth legit aim
                        local speed = math.clamp(AimbotConfig.Smoothing, 0.02, 1)
                        local alpha = math.clamp(speed * dt * 75, 0, 1)

                        local angleDot = camCF.LookVector:Dot(toTarget.Unit)
                        if angleDot < 0.9999 then
                            camera.CFrame = camCF:Lerp(desiredCF, alpha)
                        end
                    end
                end
            end
        end
    end

    --------------------------------------------------
    -- Autoshoot (uses current target)
    --------------------------------------------------
    local canAutoshoot = false
    if AimbotConfig.AutoShoot and (not AimbotConfig.AutoShootWhileKey or shouldAim) and currentTargetPlayer and currentTargetPart then
        if isVisible(camera.CFrame.Position, currentTargetPart, {LocalPlayer.Character, camera}) then
            canAutoshoot = true
        end
    end

    if canAutoshoot and mouse1press and mouse1release then
        if not autoshootDown then
            autoshootDown = true
            pcall(function() mouse1press() end)
        end
    else
        if autoshootDown and mouse1release then
            autoshootDown = false
            pcall(function() mouse1release() end)
        end
    end

    --------------------------------------------------
    -- Triggerbot (uses current target, with delay)
    --------------------------------------------------
    if AimbotConfig.Triggerbot and mouse1press and mouse1release and currentTargetPlayer and currentTargetPart then
        if isVisible(camera.CFrame.Position, currentTargetPart, {LocalPlayer.Character, camera}) then
            local mouseLoc = UserInputService:GetMouseLocation()
            local mousePos = Vector2.new(mouseLoc.X, mouseLoc.Y)
            local screenPos, onScreen = camera:WorldToViewportPoint(currentTargetPart.Position)

            if onScreen and screenPos.Z > 0 then
                local target2D = Vector2.new(screenPos.X, screenPos.Y)
                local distToCross = (mousePos - target2D).Magnitude

                -- smaller radius = more legit; larger if you want more hits
                local maxTriggerRadius = (AimbotConfig.FOVRadius or 160) * 0.35

                if distToCross <= maxTriggerRadius then
                    local delaySec = (AimbotConfig.TriggerbotDelayMs or 0) / 1000
                    if now - lastTriggerTime >= delaySec then
                        lastTriggerTime = now
                        pcall(function() mouse1press() end)
                        pcall(function() mouse1release() end)
                    end
                end
            end
        end
    end

    --------------------------------------------------
    -- Noclip logic
    --------------------------------------------------
    if NoclipConfig.Enabled and LocalPlayer.Character then
        local char = LocalPlayer.Character
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end

    --------------------------------------------------
    -- ESP update (ONLY ESP visuals)
    --------------------------------------------------
    if Drawing and ESPConfig.Enabled then
        for plr, data in pairs(ESPObjects) do
            local char = plr.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")

            if not (char and hum and hrp and hum.Health > 0) then
                if data.Box  then data.Box.Visible  = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            if ESPConfig.TeamCheck and LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team then
                if data.Box  then data.Box.Visible  = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            local rootPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if not onScreen or rootPos.Z < 0 then
                if data.Box  then data.Box.Visible  = false end
                if data.Name then data.Name.Visible = false end
                continue
            end

            local head = char:FindFirstChild("Head")
            local leg  = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftLowerLeg") or char:FindFirstChild("LeftFoot")

            local topPos    = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or rootPos
            local bottomPos = leg and camera:WorldToViewportPoint(leg.Position - Vector3.new(0, 0.5, 0))
                or camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

            local height = math.abs(topPos.Y - bottomPos.Y)
            local width  = height / 2

            if data.Box and ESPConfig.ShowBoxes then
                data.Box.Size     = Vector2.new(width, height)
                data.Box.Position = Vector2.new(rootPos.X - width / 2, topPos.Y)
                data.Box.Visible  = true
            elseif data.Box then
                data.Box.Visible = false
            end

            if data.Name and ESPConfig.ShowNames then
                data.Name.Text     = plr.Name
                data.Name.Position = Vector2.new(rootPos.X, topPos.Y - 18)
                data.Name.Visible  = true
            elseif data.Name then
                data.Name.Visible = false
            end
        end
    elseif Drawing then
        for _, data in pairs(ESPObjects) do
            if data.Box  then data.Box.Visible  = false end
            if data.Name then data.Name.Visible = false end
        end
    end
end)

